{
  "name": "subtitles-gen",
  "private": true,
  "version": "1.0.0",
  "description": "Local subtitle generator using Gemini AI",
  "author": "Subtitles Gen",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:preload\" \"vite\"",
    "dev:preload": "esbuild electron/preload.ts --bundle --platform=node --target=node16 --outdir=dist-electron --format=cjs --external:electron --watch",
    "build:preload": "esbuild electron/preload.ts --bundle --platform=node --target=node16 --outdir=dist-electron --format=cjs --external:electron",
    "build": "npm run build:preload && tsc -b && vite build",
    "build:electron": "npm run build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "electron-store": "^11.0.2",
    "fluent-ffmpeg": "^2.1.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.subtitles-gen.app",
    "productName": "Subtitles Generator",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "extraResources": [
        {
          "from": "node_modules/@ffmpeg-installer/darwin-${arch}/ffmpeg",
          "to": "ffmpeg/ffmpeg"
        },
        {
          "from": "node_modules/@ffprobe-installer/darwin-${arch}/ffprobe",
          "to": "ffprobe/ffprobe"
        }
      ]
    },
    "win": {
      "target": "nsis",
      "extraResources": [
        {
          "from": "node_modules/@ffmpeg-installer/win32-${arch}/ffmpeg.exe",
          "to": "ffmpeg/ffmpeg.exe"
        },
        {
          "from": "node_modules/@ffprobe-installer/win32-${arch}/ffprobe.exe",
          "to": "ffprobe/ffprobe.exe"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "extraResources": [
        {
          "from": "node_modules/@ffmpeg-installer/linux-${arch}/ffmpeg",
          "to": "ffmpeg/ffmpeg"
        },
        {
          "from": "node_modules/@ffprobe-installer/linux-${arch}/ffprobe",
          "to": "ffprobe/ffprobe"
        }
      ]
    }
  }
}
